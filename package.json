    "@vitest/coverage-v8": "^1.6.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jose": "^6.2.2",
    "undici": "^6.11.1",
    "zod": "^4.3.6"
  }
